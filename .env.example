# =============================================================================
# Last-Minute Life Saver — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it's in .gitignore.
# =============================================================================

# --- Backend (Cloud Run / FastAPI) ---

# Google Cloud project ID (e.g. "lifesaver-abc123")
GOOGLE_CLOUD_PROJECT=your-project-id-here

# Region — keep as us-central1 unless you have a reason to change
GOOGLE_CLOUD_LOCATION=us-central1

# Use Vertex AI via Application Default Credentials (no floating API key)
GOOGLE_GENAI_USE_VERTEXAI=true

# OAuth 2.0 client credentials for Calendar + Gmail offline flow
# Create at console.cloud.google.com → APIs & Services → Credentials
# Type: Web application. Authorized redirect URIs: https://<your-cloud-run-url>/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Fernet encryption key for storing refresh tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store in Secret Manager in production — use this env var for local dev only
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# Cloud Run service URL (set after first deploy)
BACKEND_URL=https://your-cloud-run-service-url.run.app

# Firebase Admin SDK — in Cloud Run, use the service account's ADC.
# For local dev, point to a downloaded service account key (do NOT commit the file):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json

# --- Frontend (Next.js on Firebase App Hosting) ---
# All NEXT_PUBLIC_* values are safe to include in client bundles (Firebase design)

# Firebase web app config — from Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Cloud Run backend URL (used by frontend to make API calls)
NEXT_PUBLIC_BACKEND_URL=https://your-cloud-run-service-url.run.app

# VAPID public key for FCM web push
# Generate or find at Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-public-key
