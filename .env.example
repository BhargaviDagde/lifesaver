# =============================================================================
# Last-Minute Life Saver — Environment Variables
# Copy this to .env (backend) or .env.local (frontend) and fill in real values.
# NEVER commit .env — it's in .gitignore.
# =============================================================================

# --- Backend (FastAPI on Render/Railway/Fly.io) ---

# Google Cloud project ID — still needed for Firestore + Calendar/Gmail APIs
GOOGLE_CLOUD_PROJECT=your-project-id-here

# Gemini Developer API (AI Studio) — no billing required, no service account
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-ai-studio-api-key
GOOGLE_GENAI_USE_VERTEXAI=false

# OAuth 2.0 client credentials for Calendar + Gmail offline flow
# Create at console.cloud.google.com → APIs & Services → Credentials
# Type: Web application
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Fernet encryption key for storing refresh tokens at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# Frontend URL (for CORS and OAuth redirect)
FRONTEND_URL=https://your-app-hosting-url.web.app

# Backend's own public URL (for OAuth callback URI)
BACKEND_URL=https://your-render-service.onrender.com

# Shared secret for cron-job.org → /internal/monitor-sweep authentication
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=your-long-random-secret-here

# Set to "true" in local dev to skip cron auth check
SKIP_SCHEDULER_AUTH=false

# --- Frontend (Next.js on Firebase App Hosting) ---
# All NEXT_PUBLIC_* values are safe in client bundles (Firebase design)

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Render/Railway/Fly.io backend URL
NEXT_PUBLIC_BACKEND_URL=https://your-render-service.onrender.com

# VAPID public key for FCM web push
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-public-key
